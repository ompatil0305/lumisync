# Lumisync Environment Variables Example

# Mapbox Token (Optional)
# Used for Mapbox directions API routing calculations.
# Get a token at: https://mapbox.com/
VITE_MAPBOX_TOKEN=your_mapbox_token_here

# Routing API Key (Optional)
# Used if you want to configure third-party walking routing engines.
VITE_ROUTING_API_KEY=your_routing_api_key_here
